# ============================================
# Carval Auto Backend - 环境变量配置
# ============================================
# 复制此文件为 .env 并填入实际值

# -----------------
# 服务器配置
# -----------------
PORT=3000
NODE_ENV=production

# 允许的源域名 (多个用逗号分隔)
ALLOWED_ORIGINS=https://carvalautopart.com,https://www.carvalautopart.com

# API 密钥 (用于简单 API 认证，可选)
API_KEY=your-secure-api-key-here

# -----------------
# 阿里云 OSS 配置
# -----------------
OSS_REGION=cn-hangzhou
OSS_BUCKET=carvalauto-products
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# OSS 文件路径
OSS_PRODUCTS_PATH=products.json
OSS_VERSION_PATH=version.json

# -----------------
# GitHub 配置 (用于同步数据)
# -----------------
GH_REPO=carvalauto/carvalauto.github.io
GH_TOKEN=your-github-personal-access-token
GH_BRANCH=main

# -----------------
# Google OAuth 配置
# -----------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

# -----------------
# 日志配置
# -----------------
LOG_LEVEL=info

# -----------------
# 速率限制
# -----------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
